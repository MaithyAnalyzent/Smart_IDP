# =============================================================================
# Doc Intelligence Platform — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-a-strong-random-secret-key-min-32-chars
APP_ENV=development          # development | staging | production
DEBUG=false

# Comma-separated list of allowed CORS origins (leave blank to deny all cross-origin)
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=

# Master API key for platform-level admin operations
MASTER_API_KEY=replace-with-a-strong-admin-api-key


# -----------------------------------------------------------------------------
# Database  (PostgreSQL recommended; SQLite for local dev only)
# -----------------------------------------------------------------------------
# PostgreSQL:
DATABASE_URL=postgresql://dbuser:dbpassword@localhost:5432/doc_intel
# SQLite (local dev):
# DATABASE_URL=sqlite:///./doc_intel.db

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20


# -----------------------------------------------------------------------------
# Object Storage  (S3-compatible — AWS S3 or self-hosted MinIO)
# -----------------------------------------------------------------------------
# MinIO local dev — leave STORAGE_ENDPOINT blank for real AWS S3
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_USE_SSL=false

# AWS S3 / MinIO credentials
STORAGE_ACCESS_KEY=replace-with-your-access-key
STORAGE_SECRET_KEY=replace-with-your-secret-key
STORAGE_BUCKET=doc-intel-files
STORAGE_REGION=us-east-1

# MinIO admin credentials (used by docker-compose only — not read by the app)
MINIO_ROOT_USER=replace-with-minio-admin-user
MINIO_ROOT_PASSWORD=replace-with-minio-admin-password


# -----------------------------------------------------------------------------
# LLM Provider  (choose one: openai | anthropic)
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai

# OpenAI — required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-replace-with-your-openai-api-key
# Override for Azure OpenAI or any OpenAI-compatible server:
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key


# -----------------------------------------------------------------------------
# Pipeline Tuning
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
PROCESSING_TIMEOUT_SECONDS=300
PIPELINE_CONFIG_PATH=configs/pipeline.yaml


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json              # json (production) | console (development)
